{
  "name": "todo-list",
  "displayName": "todo list",
  "description": "todo list for vscode",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:todolist-sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todolist-sidebar-view",
          "title": "ToDo List",
          "icon": "media/tasklist.svg"
        }
      ]
    },
    "views": {
      "todolist-sidebar-view": [
        {
          "type": "webview",
          "id": "todolist-sidebar",
          "name": "ToDo List",
          "icon": "media/icon.svg",
          "contextualTitle": "ToDo"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run compile-webview && npm run compile-extension",
    "compile-extension": "webpack",
    "compile-webview": "vite build --mode development",
    "watch": "concurrently -k \"npm:watch-webview\" \"npm:watch-extension\"",
    "watch-extension": "webpack --watch --config webpack.config.js",
    "watch-webview": "vite build --watch --mode development",
    "package": "npm run package-webview && npm run package-extension",
    "package-extension": "webpack --mode production --devtool hidden-source-map",
    "package-webview": "vite build --mode production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@types/vscode": "^1.79.0",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.39.0",
    "file-loader": "^6.2.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.2",
    "tslib": "^2.6.0",
    "typescript": "^5.1.6",
    "vite": "^5.4.19",
    "webpack": "^5.81.0",
    "webpack-cli": "^5.0.2"
  },
  "dependencies": {
    "concurrently": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
