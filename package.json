{
  "name": "taskdock",
  "displayName": "TaskDock",
  "description": "A lightweight sidebar todo list for managing per-project tasks inside VS Code.",
  "version": "0.0.2",
  "publisher": "shahhassan",
  "repository": {
    "type": "git",
    "url": "https://github.com/lordshady/vscodetodo"
  },
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:todolist-sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todolist-sidebar-view",
          "title": "ToDo List",
          "icon": "media/tasklist.svg"
        }
      ]
    },
    "views": {
      "todolist-sidebar-view": [
        {
          "type": "webview",
          "id": "todolist-sidebar",
          "name": "ToDo List",
          "icon": "media/icon.svg",
          "contextualTitle": "ToDo"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run compile-webview && npm run compile-extension",
    "clean-webview": "rm -f dist/style.css dist/todo-list.css dist/webview.css dist/webview.js dist/webview.js.map",
    "compile-extension": "webpack",
    "compile-webview": "npm run clean-webview && vite build --mode development",
    "watch": "concurrently -k \"npm:watch-webview\" \"npm:watch-extension\"",
    "watch-extension": "webpack --watch --config webpack.config.js",
    "watch-webview": "npm run clean-webview && vite build --watch --mode development",
    "package": "npm run package-webview && npm run package-extension",
    "package-extension": "webpack --mode production --devtool hidden-source-map",
    "package-webview": "npm run clean-webview && vite build --mode production",
    "lint": "eslint src webviews/src --ext ts,tsx"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "~1.79.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "ts-loader": "^9.5.7",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
